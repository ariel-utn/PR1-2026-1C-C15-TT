Algoritmo TP2_Ej7_Version1_Errores
	// ESTE EJERCICIO FALLA SI LA LISTA
	// DE NUMEROS INGRESADOS FUERAN TODOS NEGATIVOS
	MAX = 0
	Leer A
	Si A>MAX Entonces
		MAX = A
	FinSi
	Leer B
	Si B>MAX Entonces
		MAX = B
	FinSi
	Leer C
	Si C>MAX Entonces
		MAX = C
	FinSi
	Leer D
	Si D>MAX Entonces
		MAX = D
	FinSi
	Escribir MAX
FinAlgoritmo
