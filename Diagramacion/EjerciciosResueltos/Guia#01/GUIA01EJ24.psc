Algoritmo GUIA01EJ24
	Escribir 'Ingrese la cantidad de frascos:'
	Leer frascos
	pild_totales = frascos*75
	betamol = pild_totales*45 // mg
	micilina = pild_totales*2000 // grs
	sinitico = pild_totales*7 // mg
	Escribir 'Para ',frascos,' frascos se necesitan:'
	Escribir 'Betamol: ',betamol,' mg'
	Escribir 'Micilina: ',micilina,' mg'
	Escribir 'Ácido Sinítico: ',sinitico,' mg'
FinAlgoritmo
